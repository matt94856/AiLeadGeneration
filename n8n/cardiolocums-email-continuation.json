{
  "name": "CardioLocums — Email Enrichment Continuation",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "15,45 * * * *"
            }
          ]
        }
      },
      "id": "schedule-email-15-45",
      "name": "Every 15 and 45 past",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0],
      "notesInFlow": true,
      "notes": "Runs at :15 and :45 each hour (staggered from scoring at :00/:30). Hobby Vercel cannot run app crons more than once/day — n8n handles continuation."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://ai-lead-generation-pink.vercel.app/api/webhooks/n8n",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-webhook-secret",
              "value": "YOUR_WEBHOOK_SECRET"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"event\": \"enrichment.emails\",\n  \"data\": {\n    \"all_pending\": true,\n    \"limit\": 4\n  }\n}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "http-email-chunk",
      "name": "Process email chunk",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [280, 0],
      "notesInFlow": true,
      "notes": "Returns instantly; app processes 4 leads in background per call. No overlap with scoring at :00/:30."
    }
  ],
  "connections": {
    "Every 15 and 45 past": {
      "main": [
        [
          {
            "node": "Process email chunk",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "templateCredsSetupCompleted": false
  },
  "pinData": {}
}
