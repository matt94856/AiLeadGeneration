{
  "name": "CardioLocums — Lead Scoring Continuation",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "*/30 * * * *"
            }
          ]
        }
      },
      "id": "schedule-every-30min",
      "name": "Every 30 minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0],
      "notesInFlow": true,
      "notes": "Scores unscored leads in chunks until all physicians have a lead_score."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://ai-lead-generation-pink.vercel.app/api/webhooks/n8n",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-webhook-secret",
              "value": "YOUR_WEBHOOK_SECRET"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"event\": \"research.batch\",\n  \"data\": {\n    \"all_pending\": true,\n    \"limit\": 8\n  }\n}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "http-score-chunk",
      "name": "Process scoring chunk",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [280, 0],
      "notesInFlow": true,
      "notes": "Returns instantly; app scores up to 8 leads in background per call. Skips already-scored physicians."
    }
  ],
  "connections": {
    "Every 30 minutes": {
      "main": [
        [
          {
            "node": "Process scoring chunk",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "templateCredsSetupCompleted": false
  },
  "pinData": {}
}
