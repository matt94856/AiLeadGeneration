# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (optional — mock fallbacks used when unset)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
# Last-resort browsed email search (expensive — off by default)
OPENAI_SEARCH_MODEL=gpt-4o-mini-search-preview
ENABLE_OPENAI_WEB_SEARCH=false

# Public web search for AI email discovery (free tier: serper.dev — strongly recommended)
SERPER_API_KEY=

# Email enrichment — free-first pipeline
EMAIL_MANUAL_REVIEW_MIN_SCORE=60
# Optional: {"custom hospital name": "hospitaldomain.org"}
EMPLOYER_DOMAIN_MAP_JSON=
# Optional state license lookup page with {state}, {first_name}, {last_name}
STATE_BOARD_LICENSE_LOOKUP_URL=

# Recruiter identity (used in AI outreach drafts — defaults to Matthew Fuller if unset)
RECRUITER_FULL_NAME=Matthew Fuller
RECRUITER_EMAIL=matthewfuller389@gmail.com
RECRUITER_PHONE=3522936242
RECRUITER_TITLE=Locum tenens recruiter for cardiologists
RECRUITER_WEBSITE=locumcareerhub.com

# n8n / automation webhooks
WEBHOOK_SECRET=generate-a-long-random-secret
# Public app URL for auto-continuing batch jobs (defaults to https://VERCEL_URL on Vercel)
APP_URL=https://ai-lead-generation-pink.vercel.app

# Gmail send (Approve & Send button) — Google App Password required
GMAIL_USER=matthewfuller389@gmail.com
GMAIL_APP_PASSWORD=your-16-char-google-app-password
EMAIL_FROM_NAME=Matthew Fuller

# Optional public data integrations
STATE_BOARD_API_URL=
HOSPITAL_DIRECTORY_FEED_URL=
GROUP_PRACTICE_INDEX_URL=

# Vercel sets this automatically
VERCEL_URL=
